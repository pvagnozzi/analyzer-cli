#!/usr/bin/env zsh
set -euo pipefail

DRY_RUN=0
RUNTIME=""

show_help() {
  cat <<'EOF'
🚀 build for macOS

Synopsis:
  Build the project inside the repository build container.

Usage:
  zsh ./scripts/macos/build [--runtime docker|podman] [--dry-run] [--help]
EOF
}

log() {
  local level="$1"
  local message="$2"
  case "$level" in
    INFO) printf '\033[36mℹ️ %s\033[0m\n' "$message" ;;
    OK) printf '\033[32m✅ %s\033[0m\n' "$message" ;;
    WARN) printf '\033[33m⚠️ %s\033[0m\n' "$message" ;;
    ERR) printf '\033[31m❌ %s\033[0m\n' "$message" ;;
  esac
}

run_cmd() {
  if [[ "$DRY_RUN" -eq 1 ]]; then
    log INFO "[dry-run] $*"
  else
    eval "$*"
  fi
}

resolve_runtime() {
  if [[ -n "$RUNTIME" ]]; then
    printf '%s\n' "$RUNTIME"
    return
  fi
  if command -v docker >/dev/null 2>&1; then
    printf 'docker\n'
    return
  fi
  if command -v podman >/dev/null 2>&1; then
    printf 'podman\n'
    return
  fi
  log ERR "Neither docker nor podman is available."
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) show_help; exit 0 ;;
    --dry-run) DRY_RUN=1 ;;
    --runtime) RUNTIME="$2"; shift ;;
    *) log ERR "Unknown argument: $1"; show_help; exit 1 ;;
  esac
  shift
done

RUNTIME="$(resolve_runtime)"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
TAG="analyzer-cli-build:local"

log INFO "Using container runtime: $RUNTIME"
run_cmd "$RUNTIME build -t $TAG -f \"$REPO_ROOT/containers/build/Dockerfile\" \"$REPO_ROOT\""
run_cmd "$RUNTIME run --rm -v \"$REPO_ROOT:/workspace\" -w /workspace $TAG"
log OK "Containerized build completed."

