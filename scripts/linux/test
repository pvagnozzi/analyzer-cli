#!/usr/bin/env bash
set -euo pipefail

DRY_RUN=0
RUNTIME=""

show_help() {
  cat <<'EOF'
🚀 test for Linux

Synopsis:
  Run formatting, linting, and tests inside the repository test container.

Usage:
  bash ./scripts/linux/test [--runtime docker|podman] [--dry-run] [--help]
EOF
}

log() {
  local level="$1"
  local message="$2"
  case "$level" in
    INFO) printf '\033[36mℹ️ %s\033[0m\n' "$message" ;;
    OK) printf '\033[32m✅ %s\033[0m\n' "$message" ;;
    WARN) printf '\033[33m⚠️ %s\033[0m\n' "$message" ;;
    ERR) printf '\033[31m❌ %s\033[0m\n' "$message" ;;
  esac
}

run_cmd() {
  if [[ "$DRY_RUN" -eq 1 ]]; then
    log INFO "[dry-run] $*"
  else
    eval "$*"
  fi
}

normalize_host_path() {
  local path="$1"
  if [[ "$RUNTIME" == *.exe ]]; then
    if command -v wslpath >/dev/null 2>&1; then
      wslpath -w "$path"
      return
    fi
    if command -v cygpath >/dev/null 2>&1; then
      cygpath -aw "$path"
      return
    fi
  fi
  printf '%s\n' "$path"
}

resolve_runtime() {
  if [[ -n "$RUNTIME" ]]; then
    case "$RUNTIME" in
      podman)
        if command -v podman >/dev/null 2>&1; then
          printf 'podman\n'
          return
        fi
        if command -v podman.exe >/dev/null 2>&1; then
          printf 'podman.exe\n'
          return
        fi
        ;;
      docker)
        if command -v docker >/dev/null 2>&1; then
          printf 'docker\n'
          return
        fi
        if command -v docker.exe >/dev/null 2>&1; then
          printf 'docker.exe\n'
          return
        fi
        ;;
      *)
        printf '%s\n' "$RUNTIME"
        return
        ;;
    esac
  fi
  if command -v docker >/dev/null 2>&1; then
    printf 'docker\n'
    return
  fi
  if command -v docker.exe >/dev/null 2>&1; then
    printf 'docker.exe\n'
    return
  fi
  if command -v podman >/dev/null 2>&1; then
    printf 'podman\n'
    return
  fi
  if command -v podman.exe >/dev/null 2>&1; then
    printf 'podman.exe\n'
    return
  fi
  log ERR "Neither docker nor podman is available."
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) show_help; exit 0 ;;
    --dry-run) DRY_RUN=1 ;;
    --runtime) RUNTIME="$2"; shift ;;
    *) log ERR "Unknown argument: $1"; show_help; exit 1 ;;
  esac
  shift
done

RUNTIME="$(resolve_runtime)"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
HOST_REPO_ROOT="$(normalize_host_path "$REPO_ROOT")"
TAG="analyzer-cli-test:local"

log INFO "Using container runtime: $RUNTIME"
run_cmd "$RUNTIME build -t $TAG -f \"$HOST_REPO_ROOT\\containers\\test\\Dockerfile\" \"$HOST_REPO_ROOT\""
run_cmd "$RUNTIME run --rm -v \"$HOST_REPO_ROOT:/workspace\" -w /workspace $TAG"
log OK "Containerized test run completed."
