#!/usr/bin/env bash
set -euo pipefail

DRY_RUN=0
RUNTIME=""
BUILD_NUMBER="${ANALYZER_RELEASE_BUILD:-}"
RELEASE_DATE="${ANALYZER_RELEASE_DATE:-}"

show_help() {
  cat <<'EOF'
🚀 release for Linux

Synopsis:
  Produce Linux release zip archives for x86, amd64, and arm inside the repository release container.

Usage:
  bash ./scripts/linux/release [--runtime docker|podman] [--build-number N] [--release-date YYYYMMDD] [--dry-run] [--help]

Artifacts:
  dist/release/linux/analyzer-cli.<Major>.<Minor>.<Release>.<Build>_<YYYYMMDD>-linux-<arch>.zip
EOF
}

log() {
  local level="$1"
  local message="$2"
  case "$level" in
    INFO) printf '\033[36mℹ️ %s\033[0m\n' "$message" ;;
    OK) printf '\033[32m✅ %s\033[0m\n' "$message" ;;
    WARN) printf '\033[33m⚠️ %s\033[0m\n' "$message" ;;
    ERR) printf '\033[31m❌ %s\033[0m\n' "$message" ;;
  esac
}

run_cmd() {
  if [[ "$DRY_RUN" -eq 1 ]]; then
    log INFO "[dry-run] $*"
  else
    eval "$*"
  fi
}

resolve_runtime() {
  if [[ "$DRY_RUN" -eq 1 && -z "$RUNTIME" ]]; then
    printf 'docker\n'
    return
  fi
  if [[ -n "$RUNTIME" ]]; then
    printf '%s\n' "$RUNTIME"
    return
  fi
  if command -v docker >/dev/null 2>&1; then
    printf 'docker\n'
    return
  fi
  if command -v podman >/dev/null 2>&1; then
    printf 'podman\n'
    return
  fi
  log ERR "Neither docker nor podman is available."
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) show_help; exit 0 ;;
    --dry-run) DRY_RUN=1 ;;
    --runtime) RUNTIME="$2"; shift ;;
    --build-number) BUILD_NUMBER="$2"; shift ;;
    --release-date) RELEASE_DATE="$2"; shift ;;
    *) log ERR "Unknown argument: $1"; show_help; exit 1 ;;
  esac
  shift
done

RUNTIME="$(resolve_runtime)"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
TAG="analyzer-cli-release:local"

log INFO "Using container runtime: $RUNTIME"
[[ -n "$BUILD_NUMBER" ]] && log INFO "Using build number override: $BUILD_NUMBER"
[[ -n "$RELEASE_DATE" ]] && log INFO "Using release date override: $RELEASE_DATE"
run_cmd "$RUNTIME build -t $TAG -f \"$REPO_ROOT/containers/release/Dockerfile\" \"$REPO_ROOT\""
run_cmd "$RUNTIME run --rm -e ANALYZER_RELEASE_BUILD=\"$BUILD_NUMBER\" -e ANALYZER_RELEASE_DATE=\"$RELEASE_DATE\" -v \"$REPO_ROOT:/workspace\" -w /workspace $TAG"
log OK "Containerized release completed."
